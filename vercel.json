{
    "version": 2,
    "builds": [
        {
            "src": "server-academico.js",
            "use": "@vercel/node",
            "config": {
                "includeFiles": [
                    "*.html",
                    "*.css",
                    "config/**",
                    "middleware/**",
                    "models/**",
                    "routes/**"
                ]
            }
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "server-academico.js"
        }
    ]
}

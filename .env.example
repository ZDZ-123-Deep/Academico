# ==========================================
# EduGestión Académico - Variables de Entorno
# ==========================================
# Copiar como .env y configurar los valores

# Puerto del servidor
# En Azure esto se configura automáticamente
# En local, usar 5001 para no colisionar con Safe-entry (5000)
PORT=5001

# Ambiente
NODE_ENV=development

# ==========================================
# BASE DE DATOS MONGODB
# ==========================================
# Local: mongodb://localhost:27017/ga2026
# Atlas: mongodb+srv://usuario:password@cluster.mongodb.net/ga2026
# Cosmos DB: mongodb://cuenta:key@cuenta.mongo.cosmos.azure.com:10255/ga2026?ssl=true
MONGO_URI_ACADEMICO=mongodb://localhost:27017/ga2026

# ==========================================
# EduGestión Académico - Variables de Entorno
# ==========================================
# Copiar como .env y configurar los valores

# Puerto del servidor
# Railway/Render lo asignan automáticamente con la variable PORT
PORT=8080

# Ambiente
NODE_ENV=production

# ==========================================
# BASE DE DATOS MONGODB
# ==========================================
# Local:  mongodb://localhost:27017/ga2026
# Atlas:  mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/ga2026?appName=GestorAcademico
MONGO_URI_ACADEMICO=mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/ga2026?appName=GestorAcademico

# ==========================================
# SEGURIDAD JWT
# ==========================================
# Clave secreta para firmar tokens JWT (CAMBIAR EN PRODUCCIÓN)
JWT_SECRET=CAMBIAR_ESTA_CLAVE_EN_PRODUCCION_USAR_MINIMO_32_CARACTERES
# Tiempo de expiración del token (ej: 8h, 1d, 30m)
JWT_EXPIRATION=8h

# ==========================================
# CORS - Orígenes permitidos (separados por coma)
# ==========================================
ALLOWED_ORIGINS=https://tu-dominio.com,https://www.tu-dominio.com
